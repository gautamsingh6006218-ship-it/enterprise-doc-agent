# ── Required ───────────────────────────────────────────────────────────────────
PGVECTOR_URL=postgresql://raguser:ragpassword@localhost:5432/ragdb
JWT_SECRET=change-this-to-a-random-32-char-secret

# ── Ollama (local LLM) ─────────────────────────────────────────────────────────
OLLAMA_LLM_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434

# ── Scheduled connector sync ───────────────────────────────────────────────────
# SYNC_SOURCES=confluence,jira
# SYNC_INTERVAL_MINUTES=60
# SYNC_TENANT_ID=acme
# SYNC_OWNER_ID=system

# ── Local folder watcher ───────────────────────────────────────────────────────
# WATCH_DIR=/path/to/your/documents
# WATCH_TENANT_ID=acme
# WATCH_OWNER_ID=system
# WATCH_VISIBILITY=public
# WATCH_RECURSIVE=false

# ── Confluence connector ───────────────────────────────────────────────────────
# CONFLUENCE_URL=https://your-company.atlassian.net
# CONFLUENCE_TOKEN=your-api-token
# CONFLUENCE_USERNAME=your@email.com

# ── Jira connector ─────────────────────────────────────────────────────────────
# JIRA_URL=https://your-company.atlassian.net
# JIRA_TOKEN=your-api-token
# JIRA_USERNAME=your@email.com

# ── SharePoint connector ───────────────────────────────────────────────────────
# SP_CLIENT_ID=your-azure-app-client-id
# SP_CLIENT_SECRET=your-azure-app-client-secret
# SP_TENANT_ID=your-azure-tenant-id
# SP_SITE_URL=https://your-company.sharepoint.com/sites/yoursite

# ── MediaWiki connector ────────────────────────────────────────────────────────
# WIKI_HOST=your-wiki.example.com
# WIKI_BOT_USER=BotUsername
# WIKI_BOT_PASSWORD=BotPassword
